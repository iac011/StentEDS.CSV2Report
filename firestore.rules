rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Auth Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Validation Blueprint for StentReport
    function isValidStentReport(data) {
      return data.keys().hasAll(['sample', 'stentMaterial', 'stentRodArea', 'calcArea', 'encapArea', 'encapRatioVsCalc', 'encapRatioVsStent', 'calcDistMean', 'calcDistMax', 'calcDistMin', 'createdAt', 'status', 'ownerId'])
        && data.keys().size() == 13
        && data.sample is string && data.sample.size() <= 200
        && data.stentMaterial is string && data.stentMaterial.size() <= 100
        && data.stentRodArea is number
        && data.calcArea is number
        && data.encapArea is number
        && data.encapRatioVsCalc is number
        && data.encapRatioVsStent is number
        && data.calcDistMean is number
        && data.calcDistMax is number
        && data.calcDistMin is number
        && data.status in ['draft', 'final']
        && data.ownerId is string && data.ownerId.size() <= 128
        && data.createdAt is string;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    match /stentReports/{reportId} {
      allow create: if isVerified() 
        && isValidId(reportId)
        && isValidStentReport(request.resource.data)
        && request.resource.data.ownerId == request.auth.uid;
      
      allow read, list: if isSignedIn() 
        && resource.data.ownerId == request.auth.uid;
        
      allow update: if isVerified()
        && resource.data.ownerId == request.auth.uid
        && isValidStentReport(request.resource.data)
        && request.resource.data.ownerId == resource.data.ownerId
        && (
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])) ||
          (request.resource.data.diff(resource.data).affectedKeys().hasAll(['sample', 'stentMaterial']))
        );

      allow delete: if isVerified() && resource.data.ownerId == request.auth.uid;
    }
  }
}
